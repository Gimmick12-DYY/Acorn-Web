{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "declaration": false,
    "emitDeclarationOnly": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "data/**/*.json"]
}
